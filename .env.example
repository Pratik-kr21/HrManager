# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Get this from https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Backend ────────────────────────────────────────────────────────────────────
PORT=5000

# MongoDB Atlas connection string
# Get this from https://cloud.mongodb.com/ → Database → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — use a long random string, e.g.: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret

# Gmail App Password (NOT your real password)
# Enable 2FA on Gmail, then generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Google OAuth Client ID (same value as VITE_GOOGLE_CLIENT_ID for server-side verification)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
