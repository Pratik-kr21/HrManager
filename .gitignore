# ── Secrets & Environment Variables ───────────────────────────────────────────
# NEVER commit any .env file. Always use .env.example for templates.
.env
.env.*
!.env.example          # allow the example template to be committed
*.env
server/.env
server/.env.*
!server/.env.example

# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/
server/node_modules/

# ── Build Output ───────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.vercel/

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS & Editor Files ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.local

# VS Code (keep extensions recommendation, ignore personal settings)
.vscode/*
!.vscode/extensions.json

# JetBrains / IntelliJ
.idea/

# Windows
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ───────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
coverage/
.cache/
